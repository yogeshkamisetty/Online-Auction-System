generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String      @id @default(uuid())
  email        String      @unique
  passwordHash String
  name         String
  role         Role        @default(USER)
  suspended    Boolean     @default(false)
  createdAt    DateTime    @default(now())
  bids         Bid[]
  auctions     Auction[]
  watchlist    Watchlist[]
}

model Auction {
  id                 String             @id @default(uuid())
  title              String
  description        String
  category           String
  condition          String?
  imageUrl           String
  startPrice         Decimal            @db.Decimal(12, 2)
  currentBid         Decimal            @db.Decimal(12, 2)
  bidCount           Int                @default(0)
  endTime            DateTime
  status             AuctionStatus      @default(PENDING)
  featured           Boolean            @default(false)
  platformFee        Decimal?           @db.Decimal(12, 2)
  buyerPremium       Decimal?           @db.Decimal(12, 2)
  verificationStatus VerificationStatus @default(UNVERIFIED)
  verifiedBy         String?
  verificationNotes  String?
  sellerId           String
  seller             User               @relation(fields: [sellerId], references: [id])
  bids               Bid[]
  watchlist          Watchlist[]
  createdAt          DateTime           @default(now())
  deletedAt          DateTime?

  @@index([status, featured])
  @@index([sellerId])
  @@index([verificationStatus])
  @@index([deletedAt])
}

model Bid {
  id        String   @id @default(uuid())
  amount    Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now())
  userId    String
  auctionId String
  user      User     @relation(fields: [userId], references: [id])
  auction   Auction  @relation(fields: [auctionId], references: [id])

  @@index([auctionId, amount(desc)])
  @@index([userId])
}

model Watchlist {
  id        String   @id @default(uuid())
  userId    String
  auctionId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  auction   Auction  @relation(fields: [auctionId], references: [id], onDelete: Cascade)

  @@unique([userId, auctionId])
}

enum AuctionStatus {
  PENDING
  ACTIVE
  CLOSING
  CLOSED
  SETTLED
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
}

enum Role {
  USER
  ADMIN
}
